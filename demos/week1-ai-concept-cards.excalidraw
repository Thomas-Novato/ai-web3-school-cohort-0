    },
    {
      "type": "text",
      "id": "c1_body",
      "x": 92,
      "y": 170,
      "width": 196,
      "height": 235,
      "text": "\u2666 \u57fa\u4e8e\u4e0a\u4e0b\u6587\u8fdb\u884c\u6982\u7387\u751f\u6210\n  \u9884\u6d4b\u4e0b\u4e00\u4e2a token\n\n\u2666 \u4e0d\u662f\u4e8b\u5b9e\u672c\u8eab\n  \u81ea\u4fe1\u7f16\u9020\u5e7b\u89c9\n\n\u2666 \u6838\u5fc3\u6982\u5ff5\n  \u2022 Token: \u5904\u7406\u5355\u4f4d\n  \u2022 Embedding: \u8bed\u4e49\u5411\u91cf\n  \u2022\u00a0Hallucination: \u9700\u5916\u90e8\u6821\u9a8c\n  \u2022\u00a0Context Window: \u5de5\u4f5c\u5185\u5b58\n\n\u2666 \u5728 AIxWeb3 \u4e2d\u7684\u4f4d\u7f6e\n  LLM \u662f\u63a8\u7406\u5c42\uff0c\n  \u94fe\u4e0a\u6570\u636e\u662f\u771f\u76f8\u6e90",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#1e1e1e",
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "\u2666 \u57fa\u4e8e\u4e0a\u4e0b\u6587\u8fdb\u884c\u6982\u7387\u751f\u6210\n  \u9884\u6d4b\u4e0b\u4e00\u4e2a token\n\n\u2666 \u4e0d\u662f\u4e8b\u5b9e\u672c\u8eab\n  \u81ea\u4fe1\u7f16\u9020\u5e7b\u89c9\n\n\u2666 \u6838\u5fc3\u6982\u5ff5\n  \u2022 Token: \u5904\u7406\u5355\u4f4d\n  \u2022 Embedding: \u8bed\u4e49\u5411\u91cf\n  \u2022\u00a0Hallucination: \u9700\u5916\u90e8\u6821\u9a8c\n  \u2022\u00a0Context Window: \u5de5\u4f5c\u5185\u5b58\n\n\u2666 \u5728 AIxWeb3 \u4e2d\u7684\u4f4d\u7f6e\n  LLM \u662f\u63a8\u7406\u5c42\uff0c\n  \u94fe\u4e0a\u6570\u636e\u662f\u771f\u76f8\u6e90",
      "autoResize": true
    },

