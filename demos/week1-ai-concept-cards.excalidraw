    {
      "type": "text",
      "id": "c2_body",
      "x": 392,
      "y": 170,
      "width": 196,
      "height": 235,
      "text": "\u2666 \u4e09\u4e2a\u63a7\u5236\u5c42\u9762\n  \u2022\u00a0\u4e0a\u4e0b\u6587\u7a97\u53e3: \u5de5\u4f5c\u5185\u5b58\n  \u2022\u00a0\u7cfb\u7edf\u6307\u4ee4: \u8eab\u4efd/\u8bed\u6c14/\u8fb9\u754c\n  \u2022\u00a0Prompts: \u4efb\u52a1\u610f\u56fe\n\n\u2666 \u5143 Prompt \u601d\u8def\n  \u6211\u7684\u60f3\u6cd5 \u2192 AI \u4f18\u5316\n  \u2192 \u66f4\u597d\u7684 prompt\n  \u2192 \u66f4\u597d\u7684\u7ed3\u679c\n\n\u2666 \u6838\u5fc3\u539f\u5219\n  \u4e0d\u8981\u8ffd\u6c42\u5b8c\u7f8e prompt\n  \u91cd\u70b9\u662f\u6e05\u6670\u8868\u8fbe\u610f\u56fe\n  \u5feb\u901f\u8fed\u4ee3\u6bd4\u7406\u8bba\u91cd\u8981",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#1e1e1e",
      "textAlign": "left",
      "verticalAlign": "top",
      "originalText": "\u2666 \u4e09\u4e2a\u63a7\u5236\u5c42\u9762\n  \u2022\u00a0\u4e0a\u4e0b\u6587\u7a97\u53e3: \u5de5\u4f5c\u5185\u5b58\n  \u2022\u00a0\u7cfb\u7edf\u6307\u4ee4: \u8eab\u4efd/\u8bed\u6c14/\u8fb9\u754c\n  \u2022\u00a0Prompts: \u4efb\u52a1\u610f\u56fe\n\n\u2666 \u5143 Prompt \u601d\u8def\n  \u6211\u7684\u60f3\u6cd5 \u2192 AI \u4f18\u5316\n  \u2192 \u66f4\u597d\u7684 prompt\n  \u2192 \u66f4\u597d\u7684\u7ed3\u679c\n\n\u2666 \u6838\u5fc3\u539f\u5219\n  \u4e0d\u8981\u8ffd\u6c42\u5b8c\u7f8e prompt\n  \u91cd\u70b9\u662f\u6e05\u6670\u8868\u8fbe\u610f\u56fe\n  \u5feb\u901f\u8fed\u4ee3\u6bd4\u7406\u8bba\u91cd\u8981",
      "autoResize": true
    },

